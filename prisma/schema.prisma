generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DESIGNER
  INSTALLER
}

enum ProjectStatus {
  DRAFT
  IN_REVIEW
  PROPOSED
  APPROVED
  AS_BUILT
}

enum DesignVersionKind {
  INITIAL
  CUSTOMER_REVISION
  FIELD_ADJUSTMENT
  AS_BUILT
}

enum ShareView {
  CUSTOMER
  INSTALLER
}

enum TrainingExampleStatus {
  IN_PROGRESS
  APPROVED
  DISCARDED
}

enum CatalogCategory {
  SPRAY_BODY
  ROTOR_BODY
  SPRAY
  ROTOR
  MP_ROTATOR
  DRIP
  VALVE
  PIPE
  FITTING
  CONTROLLER
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  projects        Project[]
  pricingProfiles PricingProfile[]
  catalogItems    CatalogItem[]
  trainingExamples TrainingExample[]
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  passwordHash          String
  role                  UserRole  @default(DESIGNER)
  organizationId        String
  designTourCompletedAt DateTime?
  designTourAutoShow    Boolean   @default(true)
  trainingTourCompletedAt DateTime?
  trainingTourAutoShow    Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]    @relation("ProjectCreator")
  trainingExamples TrainingExample[] @relation("TrainingExampleCreator")
}

model Project {
  id             String        @id @default(cuid())
  name           String
  customerName   String?
  address        String?
  crmCustomerId  String?
  crmPropertyId  String?
  status         ProjectStatus @default(DRAFT)
  organizationId String
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User              @relation("ProjectCreator", fields: [createdById], references: [id])
  versions     DesignVersion[]
  shareLinks   DesignShareLink[]
}

model DesignVersion {
  id        String            @id @default(cuid())
  projectId String
  label     String
  kind      DesignVersionKind @default(INITIAL)
  isActive  Boolean           @default(false)
  designData Json
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model DesignShareLink {
  id        String    @id @default(cuid())
  projectId String
  token     String    @unique @default(cuid())
  view      ShareView @default(CUSTOMER)
  versionId String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PricingProfile {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String   @default("Default")
  isDefault          Boolean  @default(true)
  pipePerFoot        Float    @default(1.25)
  headCost           Float    @default(8.5)
  nozzleCost         Float    @default(3.5)
  headBodyCost       Float    @default(5.0)
  valveCost          Float    @default(45)
  backflowCost       Float    @default(350)
  filterCost         Float    @default(85)
  prsCost            Float    @default(45)
  flowSensorCost     Float    @default(120)
  weatherSensorCost  Float    @default(180)
  controllerCost     Float    @default(250)
  sodPerSqFt         Float    @default(1.25)
  topsoilPerSqFt     Float    @default(0.85)
  laborHourlyRate    Float    @default(65)
  hoursPerHead       Float    @default(0.25)
  hoursPerZone       Float    @default(2.5)
  hoursPer100ftPipe  Float    @default(1.5)
  hoursSlopeModifier Float    @default(0.15)
  hoursConcreteModifier Float @default(0.25)
  hoursRetainingWallModifier Float @default(0.2)
  jobMinimum         Float    @default(2500)
  grossMarginPercent Float    @default(50)
  premiumMaintenanceYearPrice Float @default(450)
  laborMultiplier    Float    @default(1.5)
  markup             Float    @default(0.25)
  targetProfitMarginPercent Float @default(50)
  crmIntegrationEnabled   Boolean @default(false)
  defaultEstimateExpiryDays Int   @default(30)
  tax                Float    @default(0.08)
  wasteFactor        Float    @default(0.1)
  fittingAssumptions Json     @default("{}")
  pipePricingByDiameter Json  @default("{}")
  catalogCostOverrides Json   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model CatalogItem {
  id             String          @id @default(cuid())
  organizationId String?
  category       CatalogCategory
  manufacturer   String
  model          String
  sku            String?
  specs          Json            @default("{}")
  nozzleChart    Json?
  isSystem       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([organizationId])
}

model TrainingExample {
  id               String                 @id @default(cuid())
  organizationId   String
  createdById      String
  status           TrainingExampleStatus  @default(IN_PROGRESS)
  algorithmVersion String
  polygonMetadata  Json
  payload          Json
  createdAt        DateTime               @default(now())
  approvedAt       DateTime?
  updatedAt        DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("TrainingExampleCreator", fields: [createdById], references: [id])

  @@index([organizationId, status])
  @@index([createdById])
}

model PlacementModelVersion {
  id                String   @id @default(cuid())
  version           String   @unique
  checkpointUrl     String
  algorithmVersion  String
  metricsJson       Json     @default("{}")
  promotionPassed   Boolean  @default(false)
  promotionNotes    String?
  isActive          Boolean  @default(false)
  trainedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
}

model PlacementInferenceLog {
  id                 String   @id @default(cuid())
  organizationId     String
  userId             String?
  source             String
  modelVersion       String?
  usedMl             Boolean  @default(false)
  shadowOnly         Boolean  @default(false)
  baselineHeadCount  Int
  refinedHeadCount   Int
  meanConfidence     Float?
  error              String?
  diagnostics        Json?
  createdAt          DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([source])
}
