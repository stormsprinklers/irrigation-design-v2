DATABASE_URL=
# Vercel + Neon integration sets DATABASE_URL (pooled) and DATABASE_URL_UNPOOLED (direct).
# db push at build time prefers DATABASE_URL_UNPOOLED, then DIRECT_URL, then DATABASE_URL.
DATABASE_URL_UNPOOLED=
DIRECT_URL=
BLOB_READ_WRITE_TOKEN=
AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# CRM estimate export (server only)
# CRM_INTEGRATION_URL=http://localhost:3000/api/integrations
# CRM_INTEGRATION_KEY=crm_int_...
# NEXT_PUBLIC_CRM_URL=http://localhost:3000

# Placement ML (optional)
ML_INFERENCE_URL=http://localhost:8000
ML_API_KEY=dev-secret
ML_MODEL_VERSION=v1
ML_INFERENCE_TIMEOUT_MS=5000
PLACEMENT_ML_ENABLED=false
PLACEMENT_ML_SHADOW=false

# Optional: auto-retrain via GitHub Actions every N approvals (also needs weekly CI)
ML_RETRAIN_ON_APPROVE=false
ML_RETRAIN_BATCH_SIZE=25
GITHUB_RETRAIN_TOKEN=
GITHUB_REPOSITORY=owner/repo
